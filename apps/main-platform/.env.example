# PostgreSQL 数据库连接（Prisma 驱动，用于聊天历史持久化）
# 格式: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:password@localhost:5432/main_platform?schema=public

# 聊天历史存储模式
# auto   → 优先 Prisma，数据库不可用时自动降级内存 Mock（默认）
# mock   → 始终使用内存 Mock（无需数据库，服务重启后数据丢失）
# prisma → 始终使用 Prisma，不自动降级（数据库必须可用）
# CHAT_HISTORY_STORAGE_MODE=auto

# Python 中心聚合服务地址（global 模式联邦检索）
FEDERATION_CENTRAL_BASE_URL=http://127.0.0.1:9000

# BFF -> central 请求超时（毫秒，默认 15000）
FEDERATION_CENTRAL_TIMEOUT_MS=15000

# BFF health 检查 central 超时（毫秒，默认 5000）
FEDERATION_CENTRAL_HEALTH_TIMEOUT_MS=5000

# 可选：BFF 直连节点健康检查（逗号分隔 node=url）
# FEDERATION_NODE_HEALTH_URLS=nodea=http://127.0.0.1:8001,nodeb=http://127.0.0.1:8002,nodec=http://127.0.0.1:8003

# 节点健康检查超时（毫秒，默认 8000）
FEDERATION_NODE_TIMEOUT_MS=8000

# Python central/node 共享 SM4 密钥（长度不足会补齐到 16 字节）
FEDERATION_SM4_KEY=replace-with-your-sm4-key
